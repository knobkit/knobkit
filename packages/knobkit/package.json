{
  "name": "knobkit",
  "version": "0.0.1",
  "description": "Rapid web app development — describe inputs and a function, get a web app.",
  "license": "MIT",
  "author": "Alain Brown",
  "type": "module",
  "types": "./dist/lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib/index.d.ts",
      "default": "./dist/lib/index.js"
    },
    "./tsconfig.base.json": "./tsconfig.base.json",
    "./package.json": "./package.json"
  },
  "bin": {
    "knobkit": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "src",
    "tsconfig.base.json"
  ],
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "pnpm run clean && pnpm run build:lib && pnpm run build:client && pnpm run typecheck",
    "build:lib": "tsc -p tsconfig.build.json",
    "build:client": "vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepare": "pnpm run build:lib && pnpm run build:client",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@huggingface/transformers": "3.8.1",
    "@revolist/react-datagrid": "^4.23.13",
    "@xstate/react": "^6.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tsx": "^4.19.0",
    "vite": "^8.0.16",
    "xstate": "^5.32.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
